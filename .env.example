# ============================================================
# points-mall-core — Environment Variables Reference
# Spring Boot reads these via ${VAR_NAME} in application-{profile}.yml.
# Copy this file as a reference; provide real values via CI/CD secrets or .env loader.
# NEVER commit files with real secrets to Git.
# ============================================================

# ── Application ─────────────────────────────────────────────
PORT=8080
# Activates application-{profile}.yml: dev | test | prod
SPRING_PROFILES_ACTIVE=dev

# ── PostgreSQL (Required) ────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=points_core
DB_USERNAME=postgres
DB_PASSWORD=

# ── Redis ───────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
# Required in production
REDIS_PASSWORD=
